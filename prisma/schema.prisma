// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  username     String?
  passwordHash String        @map("password_hash")
  role         Role          @default(USER)
  refreshToken String?       @map("refresh_token")
  vehicles     Vehicle[]
  serviceTypes ServiceType[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Vehicle {
  id              String  @id @default(uuid())
  userId          String  @map("user_id")
  name            String
  brand           String
  model           String
  year            String?
  vin             String?
  initialOdometer Float   @map("initial_odometer")
  trackerDistance Float?  @map("tracker_distance")

  user             User              @relation(fields: [userId], references: [id])
  device           Device?
  serviceRecords   ServiceRecord[]
  serviceIntervals ServiceInterval[]
  vehicleState     VehicleState?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vehicles")
}

model Device {
  id              String   @id @default(uuid())
  imei            String
  vehicleId       String   @unique @map("vehicle_id")
  firmwareVersion String   @map("firmware_version")
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  tracks          Track[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("devices")
}

model Telemetry {
  deviceId  String   @map("device_id")
  timestamp DateTime

  latitude  Float?
  longitude Float?

  speed       Float?
  rpm         Int?
  coolantTemp Int?   @map("coolant_temp")
  fuelLevel   Float? @map("fuel_level")

  createdAt DateTime @default(now()) @map("created_at")

  @@id([deviceId, timestamp])
  @@index([timestamp])
  @@map("telemetry")
}

model Track {
  id             String   @id @default(uuid())
  deviceId       String   @map("device_id")
  device         Device   @relation(fields: [deviceId], references: [id])
  name           String
  startTimestamp DateTime @map("start_timestamp")
  endTimestamp   DateTime @map("end_timestamp")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("track")
}

model ServiceType {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  name        String
  description String?

  user      User              @relation(fields: [userId], references: [id])
  records   ServiceRecord[]
  intervals ServiceInterval[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_type")
}

model ServiceRecord {
  id            String @id @default(uuid())
  vehicleId     String @map("vehicle_id")
  serviceTypeId String @map("service_type_id")

  performedAt       DateTime @map("performed_at")
  performedOdometer Float?   @map("performed_odometer")
  comment           String?

  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_record")
}

model ServiceInterval {
  id            String @id @default(uuid())
  vehicleId     String @map("vehicle_id")
  serviceTypeId String @map("service_type_id")

  intervalKm   Float @map("interval_km")
  intervalDays Int   @map("interval_days")

  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([vehicleId, serviceTypeId])
  @@map("service_interval")
}

model VehicleState {
  vehicleId String @id @map("vehicle_id")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  lastSeen DateTime @map("last_seen")

  latitude  Float
  longitude Float

  speed       Float?
  rpm         Int?
  coolantTemp Int?   @map("coolant_temp")
  fuelLevel   Float? @map("fuel_level")

  currentOdometer Float @map("current_odometer")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}
